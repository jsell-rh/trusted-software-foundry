{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "https://github.com/jsell-rh/trusted-software-components/tsc/spec/schema.json",
  "title": "TSC Application IR Spec",
  "description": "Intermediate Representation for a Trusted Software Components application. AI agents write this file; the TSC compiler assembles audited components to produce a working binary.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "components"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["tsc/v1", "tsc/v2"],
      "description": "API version of this spec. 'tsc/v1' for CRUD apps; 'tsc/v2' for complex apps (graph, events, authz). Hooks are available in both versions."
    },
    "kind": {
      "type": "string",
      "const": "Application",
      "description": "Resource kind. Must be 'Application'."
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Application name in kebab-case."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Application version in semver (e.g. 1.0.0)."
        },
        "description": {
          "type": "string",
          "description": "Optional human-readable description."
        }
      }
    },
    "components": {
      "type": "object",
      "description": "SBOM: pinned versions of all trusted components used by this application. Each key is a component name; value is a semver version string.",
      "propertyNames": {
        "enum": [
          "tsc-http",
          "tsc-postgres",
          "tsc-auth-jwt",
          "tsc-grpc",
          "tsc-health",
          "tsc-metrics",
          "tsc-events"
        ]
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
        "description": "Semver version string, e.g. v1.0.0."
      },
      "minProperties": 1
    },
    "resources": {
      "type": "array",
      "description": "Data resources managed by this application.",
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rest": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "base_path": {
              "type": "string",
              "pattern": "^/",
              "default": "/api/v1",
              "description": "Base URL path for the REST API."
            },
            "version_header": {
              "type": "boolean",
              "default": true,
              "description": "Include X-API-Version header in responses."
            }
          }
        },
        "grpc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 9000
            }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["jwt", "none"],
          "description": "Authentication mechanism."
        },
        "jwk_url": {
          "type": "string",
          "description": "URL or env-var reference for JWK public key endpoint. Required when type=jwt."
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "When true, unauthenticated requests are rejected."
        },
        "allow_mock": {
          "type": "string",
          "description": "Env-var reference (e.g. '${OCM_MOCK_ENABLED}'). When true, accept mock tokens."
        }
      },
      "if": { "properties": { "type": { "const": "jwt" } } },
      "then": { "required": ["jwk_url"] }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["postgres"],
          "description": "Database type. Only 'postgres' is supported."
        },
        "migrations": {
          "type": "string",
          "enum": ["auto", "manual"],
          "default": "auto",
          "description": "Migration strategy. 'auto' means the compiler generates SQL migration files."
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "health_check": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 8083
            },
            "path": {
              "type": "string",
              "default": "/healthz"
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 8080
            },
            "path": {
              "type": "string",
              "default": "/metrics"
            }
          }
        }
      }
    },
    "hooks": {
      "type": "array",
      "description": "Custom code hooks — the escape hatch for business logic that trusted components cannot cover. The AI declares hook points; human engineers implement the Go functions. The compiler copies hooks/*.go unchanged into the generated project and generates call sites at each declared lifecycle point.",
      "items": { "$ref": "#/$defs/hook" }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "required": ["name", "plural", "fields", "operations"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "Singular resource name in PascalCase, e.g. 'Dinosaur'."
        },
        "plural": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Plural name in lowercase-kebab used in API paths, e.g. 'dinosaurs'."
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["create", "read", "update", "delete", "list"]
          },
          "uniqueItems": true
        },
        "events": {
          "type": "boolean",
          "default": false,
          "description": "When true, emit PostgreSQL LISTEN/NOTIFY events on every mutation."
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Field name in snake_case."
        },
        "type": {
          "type": "string",
          "enum": ["string", "int", "float", "bool", "timestamp", "uuid"],
          "description": "Scalar field type."
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "max_length": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum length for string fields. Omit for unlimited."
        },
        "auto": {
          "type": "string",
          "enum": ["created", "updated"],
          "description": "Auto-populate strategy: 'created' sets on insert; 'updated' sets on insert and update."
        },
        "soft_delete": {
          "type": "boolean",
          "default": false,
          "description": "When true, this timestamp field is the soft-delete marker. List queries exclude soft-deleted records."
        }
      }
    },
    "hook": {
      "type": "object",
      "required": ["name", "point", "implementation"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique hook name in kebab-case, e.g. 'enrich-request-context'."
        },
        "point": {
          "type": "string",
          "enum": ["pre-handler", "post-handler", "pre-db", "post-db", "pre-publish", "post-consume"],
          "description": "Lifecycle point where custom code is injected. 'pre-handler'/'post-handler': HTTP request lifecycle. 'pre-db'/'post-db': database operation lifecycle. 'pre-publish'/'post-consume': event bus lifecycle."
        },
        "service": {
          "type": "string",
          "description": "Service name this hook applies to (from services[] block, or omit for single-service apps)."
        },
        "routes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "HTTP route patterns this hook applies to (for pre/post-handler hooks). Omit to apply to all routes."
        },
        "topic": {
          "type": "string",
          "description": "Event topic name this hook applies to (for pre-publish/post-consume hooks)."
        },
        "resources": {
          "oneOf": [
            { "type": "string", "const": "all" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Resource names this hook applies to (for pre-db/post-db hooks). 'all' or a list of resource names."
        },
        "implementation": {
          "type": "string",
          "pattern": "^hooks/[a-z][a-z0-9_/]*\\.go$",
          "description": "Path to the human-written Go file implementing this hook, relative to the repo root. Must be under hooks/. The compiler copies this file into the generated project and generates a typed call site."
        }
      }
    }
  }
}
