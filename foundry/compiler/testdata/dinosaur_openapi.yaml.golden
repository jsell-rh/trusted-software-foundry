components:
  schemas:
    ServiceError:
      type: object
      required: [code, http_status, reason]
      properties:
        code:
          type: integer
          description: "Foundry error code"
          example: 7
        http_status:
          type: integer
          description: "HTTP status code"
          example: 404
        reason:
          type: string
          description: "Human-readable error message"
          example: "Resource not found"
    Dinosaur:
      type: object
      required:
        - id
        - species
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        species:
          type: string
          maxLength: 100
        description:
          type: string
          nullable: true
        weight_kg:
          type: number
          format: double
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        deleted_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
    DinosaurInput:
      type: object
      required:
        - species
      properties:
        species:
          type: string
          maxLength: 100
        description:
          type: string
          nullable: true
        weight_kg:
          type: number
          format: double
          nullable: true
    DinosaurList:
      type: object
      required: [kind, page, size, total, items]
      properties:
        kind:
          type: string
          example: "DinosaurList"
        page:
          type: integer
        size:
          type: integer
        total:
          type: integer
        items:
          type: array
          items:
            $ref: "#/components/schemas/Dinosaur"
