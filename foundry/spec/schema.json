{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "https://github.com/jsell-rh/trusted-software-foundry/tsc/spec/schema.json",
  "title": "Trusted Software Foundry Application Spec",
  "description": "Intermediate Representation for a Trusted Software Foundry application. AI agents write this file; the forge compiler assembles audited, version-pinned trusted components to produce a working binary. From simple CRUD services to complex graph/event-driven/multi-service platforms — one schema, one compiler, one trust model.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "components"],
  "additionalProperties": false,
  "properties": {

    "apiVersion": {
      "type": "string",
      "const": "foundry/v1",
      "description": "Schema version. Always 'foundry/v1'."
    },
    "kind": {
      "type": "string",
      "const": "Application",
      "description": "Resource kind. Always 'Application'."
    },

    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Application name in kebab-case, e.g. 'my-service'."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Application version in semver, e.g. '1.0.0'."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this application does."
        }
      }
    },

    "components": {
      "type": "object",
      "description": "SBOM: pinned versions of trusted components used by this application. Each key is a component name; value is a semver version string (e.g. v1.0.0). This block is the application's trust boundary — only listed components are permitted.",
      "propertyNames": {
        "enum": [
          "foundry-http",
          "foundry-postgres",
          "foundry-auth-jwt",
          "foundry-auth-spicedb",
          "foundry-grpc",
          "foundry-health",
          "foundry-metrics",
          "foundry-events",
          "foundry-graph-age",
          "foundry-kafka",
          "foundry-nats",
          "foundry-redis",
          "foundry-redis-streams",
          "foundry-temporal",
          "foundry-tenancy",
          "foundry-service-router"
        ]
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
        "description": "Semver version string, e.g. v1.0.0."
      },
      "minProperties": 1
    },

    "resources": {
      "type": "array",
      "description": "Relational data resources managed by this application. Each resource gets a database table, CRUD handlers, SQL migrations, and optional event emission.",
      "items": { "$ref": "#/$defs/resource" }
    },

    "graph": {
      "$ref": "#/$defs/graphConfig",
      "description": "Property graph configuration (Apache AGE / PostgreSQL). Enables node/edge CRUD, Cypher queries, and bulk mutation loading. Requires foundry-graph-age component."
    },

    "services": {
      "type": "array",
      "description": "Multi-service decomposition. When present, forge compile generates a separate entrypoint per service (main_<name>.go) plus a docker-compose.yaml. Each service activates a subset of components and resources.",
      "items": { "$ref": "#/$defs/service" }
    },

    "events": {
      "$ref": "#/$defs/eventsConfig",
      "description": "Event bus configuration. Supports Kafka, NATS, Redis Streams, or PostgreSQL LISTEN/NOTIFY. Defines topics, producers, consumers, and optional schema registry."
    },

    "authz": {
      "$ref": "#/$defs/authzConfig",
      "description": "Fine-grained authorization. Supports SpiceDB (ReBAC/Zanzibar), OPA, or casbin. Binds resource operations to permission checks. Requires foundry-auth-spicedb or compatible component."
    },

    "state": {
      "$ref": "#/$defs/stateConfig",
      "description": "External state backends (Redis). Configures caching, rate limiting, and distributed locking. Requires foundry-redis component."
    },

    "bi_temporal": {
      "$ref": "#/$defs/biTemporalConfig",
      "description": "Bi-temporal data tracking (valid time + transaction time). Generates current/history table pairs and AS-OF query endpoints. Requires foundry-temporal component."
    },

    "workflows": {
      "$ref": "#/$defs/workflowsConfig",
      "description": "Temporal.io durable workflow engine configuration. Declares long-running workflows, their activities, and trigger events. Requires foundry-temporal component."
    },

    "tenancy": {
      "$ref": "#/$defs/tenancyConfig",
      "description": "Multi-tenancy isolation. Supports schema-per-tenant, row-level, or database-per-tenant models. Requires foundry-tenancy component."
    },

    "hooks": {
      "type": "array",
      "description": "Custom code escape hatches. AI declares hook points in the IR; engineers implement the Go files. The compiler generates type-safe call sites and copies hook files into the output unchanged. This is the ONLY mechanism for injecting custom logic into a Foundry application.",
      "items": { "$ref": "#/$defs/hook" }
    },

    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rest": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "base_path": {
              "type": "string",
              "pattern": "^/",
              "default": "/api/v1",
              "description": "Base URL path for the REST API, e.g. '/api/v1'."
            },
            "version_header": {
              "type": "boolean",
              "default": true,
              "description": "Include X-API-Version header in responses."
            }
          }
        },
        "grpc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 9000
            }
          }
        }
      }
    },

    "auth": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["jwt", "none"],
          "description": "Authentication mechanism. 'jwt' requires foundry-auth-jwt; 'none' disables auth middleware."
        },
        "jwk_url": {
          "type": "string",
          "description": "JWK public key endpoint URL or env-var reference, e.g. '${JWK_CERT_URL}'. Required when type=jwt."
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "When true, unauthenticated requests are rejected with 401."
        },
        "allow_mock": {
          "type": "string",
          "description": "Env-var reference. When the referenced var is 'true', mock JWT tokens are accepted. For development only."
        }
      },
      "if": { "properties": { "type": { "const": "jwt" } } },
      "then": { "required": ["jwk_url"] }
    },

    "database": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["postgres"],
          "description": "Database engine. Only 'postgres' is supported."
        },
        "migrations": {
          "type": "string",
          "enum": ["auto", "manual"],
          "default": "auto",
          "description": "'auto': forge compile generates SQL migration files from resource definitions. 'manual': engineer manages migrations."
        }
      }
    },

    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "health_check": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8083 },
            "path": { "type": "string", "default": "/healthz" }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8080 },
            "path": { "type": "string", "default": "/metrics" }
          }
        }
      }
    }

  },

  "$defs": {

    "resource": {
      "type": "object",
      "required": ["name", "plural", "fields", "operations"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "Singular resource name in PascalCase, e.g. 'Dinosaur'."
        },
        "plural": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Plural form in lowercase-kebab, used in API paths, e.g. 'dinosaurs'."
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["create", "read", "update", "delete", "list"]
          }
        },
        "events": {
          "type": "boolean",
          "default": false,
          "description": "When true and events backend is pg-notify (or no events block), emit PostgreSQL LISTEN/NOTIFY on every mutation. When using a full events: block, declare producers/consumers there instead."
        }
      }
    },

    "field": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Field name in snake_case."
        },
        "type": {
          "type": "string",
          "enum": ["string", "int", "float", "bool", "timestamp", "uuid"],
          "description": "Scalar field type."
        },
        "required":    { "type": "boolean", "default": false },
        "max_length":  { "type": "integer", "minimum": 1, "description": "Max length for string fields." },
        "auto": {
          "type": "string",
          "enum": ["created", "updated"],
          "description": "'created': auto-set on insert. 'updated': auto-set on insert and update."
        },
        "soft_delete": {
          "type": "boolean",
          "default": false,
          "description": "When true, this timestamp is the soft-delete marker. List queries exclude soft-deleted records."
        }
      }
    },

    "graphConfig": {
      "type": "object",
      "required": ["backend"],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["age"],
          "description": "Graph storage backend. 'age' = Apache AGE (PostgreSQL extension). Requires foundry-graph-age component."
        },
        "graph_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Name of the AGE graph to create/use. Defaults to the application name with underscores."
        },
        "node_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/graphNodeType" }
        },
        "edge_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/graphEdgeType" }
        },
        "mutations": { "$ref": "#/$defs/graphMutationsConfig" },
        "queries":   { "$ref": "#/$defs/graphQueriesConfig" }
      }
    },

    "graphNodeType": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": false,
      "properties": {
        "label":    { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9]*$", "description": "AGE node label in PascalCase (e.g. 'Cluster')." },
        "id_field": { "type": "string", "description": "Field used as the node identity key. Defaults to 'id'." },
        "properties": {
          "type": "array",
          "description": "Property names stored on this node. Type is resolved from the resource definition.",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      }
    },

    "graphEdgeType": {
      "type": "object",
      "required": ["label", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "label":    { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$", "description": "AGE edge label in SCREAMING_SNAKE_CASE (e.g. 'HAS_NODE_POOL')." },
        "from":     { "type": "string", "description": "Source node label." },
        "to":       { "type": "string", "description": "Target node label." },
        "directed": { "type": "boolean", "default": true },
        "properties": {
          "type": "array",
          "description": "Property names stored on this edge.",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      }
    },

    "graphMutationsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operations": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["DEFINE", "CREATE", "UPDATE", "DELETE"] }
        },
        "bulk_loading":    { "type": "boolean", "default": false, "description": "Enable bulk JSONL mutation loading endpoint." },
        "mutation_format": { "type": "string", "enum": ["jsonl", "json"], "default": "json" }
      }
    },

    "graphQueriesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language":   { "type": "string", "enum": ["cypher"], "default": "cypher" },
        "max_depth":  { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
        "expose_api": { "type": "boolean", "default": true, "description": "Generate REST and gRPC query endpoints." }
      }
    },

    "service": {
      "type": "object",
      "required": ["name", "role"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "description": { "type": "string", "description": "Human-readable description of this service's responsibility." },
        "role": {
          "type": "string",
          "enum": ["rest-api", "grpc-api", "worker", "metrics", "scheduler", "gateway"],
          "description": "Service role determines the generated entrypoint template."
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "components": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Subset of top-level components activated in this service."
        },
        "resources": {
          "oneOf": [
            { "type": "string", "const": "all" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Resources owned by this service. 'all' or a list of resource names."
        },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/serviceTrigger" }
        }
      }
    },

    "serviceTrigger": {
      "type": "object",
      "required": ["event", "handler"],
      "additionalProperties": false,
      "properties": {
        "event":   { "type": "string", "description": "Event topic or name that activates this handler." },
        "handler": { "type": "string", "description": "Handler name in the generated worker dispatch table." }
      }
    },

    "eventsConfig": {
      "type": "object",
      "required": ["backend"],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["kafka", "nats", "redis-streams", "pg-notify"],
          "description": "Event bus backend."
        },
        "broker_url":      { "type": "string", "description": "Broker URL shorthand, e.g. '${KAFKA_BROKER_URL}'. Equivalent to broker.url." },
        "broker":          { "$ref": "#/$defs/eventsBroker" },
        "schema_registry": { "$ref": "#/$defs/eventsSchemaRegistry" },
        "topics":          { "type": "array", "items": { "$ref": "#/$defs/eventTopic" } },
        "producers":       { "type": "array", "items": { "$ref": "#/$defs/eventProducer" } },
        "consumers":       { "type": "array", "items": { "$ref": "#/$defs/eventConsumer" } }
      }
    },

    "eventsBroker": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "description": "Broker URL or env-var reference, e.g. '${KAFKA_BOOTSTRAP_SERVERS}'." }
      }
    },

    "eventsSchemaRegistry": {
      "type": "object",
      "required": ["url", "format"],
      "additionalProperties": false,
      "properties": {
        "url":    { "type": "string" },
        "format": { "type": "string", "enum": ["avro", "json", "protobuf"] }
      }
    },

    "eventTopic": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name":            { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
        "resource":        { "type": "string", "description": "Resource whose lifecycle events are published to this topic." },
        "operations": {
          "type": "array",
          "description": "Resource operations that trigger an event on this topic.",
          "items": { "type": "string", "enum": ["create", "read", "update", "delete", "list"] }
        },
        "partitions":      { "type": "integer", "minimum": 1, "default": 1 },
        "replication":     { "type": "integer", "minimum": 1, "default": 1 },
        "retention_hours": { "type": "integer", "minimum": 1 },
        "schema":          { "type": "string", "description": "Resource name or schema reference for event payload." },
        "role": {
          "type": "string",
          "enum": ["standard", "dead-letter-queue"],
          "default": "standard"
        },
        "source": {
          "type": "string",
          "description": "For dead-letter-queue topics: the source topic that feeds this DLQ."
        }
      }
    },

    "eventProducer": {
      "type": "object",
      "required": ["service", "topics"],
      "additionalProperties": false,
      "properties": {
        "service": { "type": "string" },
        "topics":  { "type": "array", "items": { "type": "string" } }
      }
    },

    "eventConsumer": {
      "type": "object",
      "required": ["service", "topics"],
      "additionalProperties": false,
      "properties": {
        "service":     { "type": "string" },
        "topics":      { "type": "array", "items": { "type": "string" } },
        "group_id":    { "type": "string", "description": "Consumer group ID, e.g. '${APP_NAME}-worker'." },
        "error_topic": { "type": "string", "description": "Dead-letter topic for failed messages." }
      }
    },

    "authzConfig": {
      "type": "object",
      "required": ["backend"],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["spicedb", "opa", "casbin"],
          "description": "Authorization backend. 'spicedb' requires foundry-auth-spicedb."
        },
        "spicedb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "endpoint": { "type": "string", "description": "SpiceDB gRPC endpoint, e.g. '${SPICEDB_ENDPOINT}'." },
            "token":    { "type": "string", "description": "API token, e.g. '${SPICEDB_TOKEN}'." },
            "tls":      { "type": "boolean", "default": true }
          }
        },
        "schema_file": {
          "type": "string",
          "description": "Relative path to the authz schema (e.g. 'authz/schema.zed'). Human-written; not generated by forge."
        },
        "enforcement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": {
              "type": "string",
              "enum": ["deny", "allow"],
              "default": "deny",
              "description": "Default decision when no policy matches. 'deny' is safe; 'allow' is permissive."
            }
          }
        },
        "relations": {
          "type": "array",
          "description": "SpiceDB relation declarations — maps resource types to subject types.",
          "items": { "$ref": "#/$defs/authzRelation" }
        },
        "policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/authzPolicy" }
        }
      }
    },

    "authzRelation": {
      "type": "object",
      "required": ["resource", "relation", "subject"],
      "additionalProperties": false,
      "properties": {
        "resource": { "type": "string", "description": "Resource type name (e.g. 'Cluster')." },
        "relation": { "type": "string", "description": "Relation name (e.g. 'owner', 'viewer')." },
        "subject":  { "type": "string", "description": "Subject type (e.g. 'User', 'Organization')." }
      }
    },

    "authzPolicy": {
      "type": "object",
      "required": ["resource", "operations"],
      "additionalProperties": false,
      "properties": {
        "resource":     { "type": "string", "description": "Resource name this policy applies to." },
        "subject_type": { "type": "string", "default": "user" },
        "object_type":  { "type": "string" },
        "operations": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Maps CRUD operation name to authz permission string, e.g. {\"read\": \"can_view\"}."
        }
      }
    },

    "stateConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "External distributed state via Redis. Configures caching, rate limiting, and distributed locking.",
      "properties": {
        "backend": { "type": "string", "enum": ["redis"], "default": "redis" },
        "url":     { "type": "string", "description": "Redis connection URL or env-var ref, e.g. '${REDIS_URL}'." },
        "keys": {
          "type": "array",
          "description": "Named state entries with strategies.",
          "items": { "$ref": "#/$defs/stateKey" }
        },
        "backends": {
          "type": "array",
          "description": "Named backend pool (advanced: multiple Redis instances).",
          "items": { "$ref": "#/$defs/stateBackend" }
        },
        "uses": {
          "type": "array",
          "items": { "$ref": "#/$defs/stateUse" }
        }
      }
    },

    "stateKey": {
      "type": "object",
      "required": ["name", "strategy"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "description": "Logical key name." },
        "resource":    { "type": "string", "description": "Resource this key is scoped to (optional)." },
        "strategy":    { "type": "string", "enum": ["cache", "distributed_lock", "rate_limit", "counter"], "description": "How this key is used." },
        "ttl_seconds": { "type": "integer", "minimum": 1, "description": "Time-to-live in seconds." }
      }
    },

    "stateBackend": {
      "type": "object",
      "required": ["name", "type", "url"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "type":        { "type": "string", "enum": ["redis"] },
        "url":         { "type": "string" },
        "default_ttl": { "type": "integer", "minimum": 1 }
      }
    },

    "stateUse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cache":              { "type": "string" },
        "rate_limit":         { "type": "string" },
        "distributed_lock":   { "type": "string" },
        "resources": {
          "oneOf": [
            { "type": "string", "const": "all" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "routes":               { "type": "array", "items": { "type": "string" } },
        "requests_per_second":  { "type": "integer", "minimum": 1 },
        "burst":                { "type": "integer", "minimum": 1 },
        "operations": {
          "type": "array",
          "items": { "type": "string", "enum": ["create", "read", "update", "delete", "list"] }
        }
      }
    },

    "biTemporalConfig": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "valid_time": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "field": { "type": "string", "description": "Resource field name that marks when the data became true in the world." }
          }
        },
        "transaction_time": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "auto": {
              "type": "boolean",
              "default": true,
              "description": "When true, forge generates current/history table pairs and middleware to maintain transaction time automatically."
            }
          }
        },
        "resources": {
          "oneOf": [
            { "type": "string", "const": "all" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Which resources get bi-temporal tracking. 'all' or a list of resource names."
        },
        "query_api": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "as_of_param":   { "type": "string", "default": "as_of",    "description": "Query parameter for point-in-time queries." },
            "between_param": { "type": "string", "default": "between",  "description": "Query parameter for range queries." }
          }
        }
      }
    },

    "workflowsConfig": {
      "type": "object",
      "required": ["namespace", "worker_queue"],
      "additionalProperties": false,
      "description": "Temporal.io workflow engine configuration.",
      "properties": {
        "namespace":    { "type": "string", "description": "Temporal namespace. Defaults to application name." },
        "worker_queue": { "type": "string", "description": "Task queue name for worker polling." },
        "host":         { "type": "string", "description": "Temporal gRPC host:port. Default: localhost:7233." },
        "workflows": {
          "type": "array",
          "description": "Workflow definitions — each maps a resource lifecycle trigger to a sequence of activities.",
          "items": { "$ref": "#/$defs/workflowDefinition" }
        }
      }
    },

    "workflowDefinition": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name":       { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9]*$", "description": "Workflow name in PascalCase." },
        "resource":   { "type": "string", "description": "Resource that triggers this workflow." },
        "trigger":    { "type": "string", "enum": ["create", "update", "delete", "schedule"], "description": "Lifecycle event that starts this workflow." },
        "activities": {
          "type": "array",
          "description": "Ordered list of activity names. Engineers implement each as a Go function.",
          "items": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9]*$" }
        }
      }
    },

    "tenancyConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "Multi-tenant isolation. The presence of this block enables tenancy. strategy defaults to 'row'.",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["schema", "row", "database"],
          "default": "row",
          "description": "'row': tenant column on every table (most common). 'schema': PostgreSQL schema per tenant. 'database': separate database per tenant."
        },
        "field":  { "type": "string", "default": "org_id",           "description": "Column name injected into every resource table (strategy=row)." },
        "header": { "type": "string", "default": "X-Organization-Id","description": "HTTP header from which the tenant identifier is extracted." },
        "claim":  { "type": "string", "description": "JWT claim name to extract tenant ID from (falls back to header)." },
        "resources": {
          "oneOf": [
            { "type": "string", "const": "all" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Which resources are tenant-scoped. Default: all."
        },
        "admin_bypass": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "role": { "type": "string", "description": "JWT role that bypasses tenant filtering for platform admins." }
          }
        }
      }
    },

    "hook": {
      "type": "object",
      "required": ["name", "point", "implementation"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Hook identifier, used as the generated function name."
        },
        "point": {
          "type": "string",
          "enum": ["pre-handler", "post-handler", "pre-db", "post-db", "pre-publish", "post-consume"],
          "description": "Lifecycle injection point. pre-handler/post-handler: HTTP middleware chain. pre-db/post-db: wraps DAO calls. pre-publish: wraps event producer. post-consume: wraps event consumer handler."
        },
        "service":  { "type": "string", "description": "Service this hook applies to (for multi-service apps)." },
        "routes":   { "type": "array", "items": { "type": "string" }, "description": "HTTP route patterns this hook intercepts (pre/post-handler only)." },
        "topic":    { "type": "string", "description": "Event topic this hook intercepts (pre-publish/post-consume only)." },
        "implementation": {
          "type": "string",
          "pattern": "^hooks/[a-z][a-z0-9_/]*.go$",
          "description": "Relative path to the human-written Go file. Must be under hooks/. forge compile copies it unchanged into the generated project and generates a typed call site."
        }
      }
    }

  }
}
